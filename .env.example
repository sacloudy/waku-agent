# ── Required ────────────────────────────────────────────────────────────────
# The only key you need for the default clone-and-run experience.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── LLM (optional) ──────────────────────────────────────────────────────────
# Any Anthropic-compatible endpoint works (Moonshot/Kimi, GLM, ...): set its
# base URL here and put its key in ANTHROPIC_API_KEY above.
# ANTHROPIC_BASE_URL=

# Main model (the loop) and small model (retrieval gate + consolidation judge).
# JARVIS_MODEL=claude-sonnet-5
# JARVIS_SMALL_MODEL=claude-haiku-4-5-20251001

# ── Jarvis home (optional) ──────────────────────────────────────────────────
# Where memory (state.db), calendar.ics, outbox/ and traces/ live.
# JARVIS_HOME=.jarvis

# ── Loop guardrails (optional) ──────────────────────────────────────────────
# JARVIS_MAX_ITERATIONS=10
# JARVIS_MAX_TOKENS=2048

# ── Memory tuning (optional) ────────────────────────────────────────────────
# Consolidate chats into durable facts only after N new exchanges.
# JARVIS_CONSOLIDATE_EVERY=6
# JARVIS_RETRIEVAL_TOP_K=4

# ── Tracing (optional): pip install -e '.[tracing]' ────────────────────────
# JSONL traces are ALWAYS written to $JARVIS_HOME/traces/. To also see them in
# a dashboard: run `make trace` (Phoenix on localhost:6006) and uncomment:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# (Langfuse cloud speaks OTel too — use their endpoint + auth headers instead.)

# ── Telegram gateway (optional): pip install -e '.[telegram]' ──────────────
# Create a bot: message @BotFather → /newbot. Find your numeric user id via
# @userinfobot to lock the bot to yourself.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER=

# ── Supabase vector memory (optional): pip install -e '.[supabase]' ────────
# The launch-rag upgrade path: run sql/init_supabase.sql on a fresh project.
# JARVIS_SEMANTIC_STORE=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# OPENAI_API_KEY=          # embeddings only (text-embedding-3-small)
